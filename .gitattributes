# Auto detect text files and normalize line endings to LF in repo
* text=auto eol=lf

# Explicitly declare text files
*.py text
*.md text
*.rst text
*.txt text
*.yaml text
*.yml text
*.toml text
*.css text
*.html text
*.json text
*.ini text
*.cfg text

# Denote binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# GitHub linguist: documentation
/docs/* linguist-documentation
*.md linguist-documentation=true

# GitHub linguist: vendored (if any)
# path/to/vendor linguist-vendored
